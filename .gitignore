# 1. Kecualikan semua file Google Apps Script (.gs)
*.gs

# 2. Kecualikan folder konfigurasi IDE / Editor
.vscode/
.idea/

# 3. Kecualikan file konfigurasi rahasia & environment
.env
.env.local
.clasp.json
clasprc.json

# 4. Kecualikan file sistem operasi
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# 5. Kecualikan log dan cache
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 6. Kecualikan node_modules jika nanti memakai npm
node_modules/
